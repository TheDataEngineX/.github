{
	"servers": {
		"context7": {
			"command": "npx",
			"args": [
				"-y",
				"@upstash/context7-mcp@latest"
			],
			"type": "stdio"
		},
		"filesystem": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"${workspaceFolder}"
			]
		},
		"git": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"mcp-server-git",
				"--repository",
				"${workspaceFolder}"
			]
		},
		"fetch": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"mcp-server-fetch"
			]
		}
	}
}